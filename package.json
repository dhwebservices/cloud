  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/dhwebservices/cloud/issues"
  },
  "homepage": "https://github.com/dhwebservices/cloud#readme",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^6.9.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
