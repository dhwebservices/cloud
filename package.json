{
  "name": "dh-cloud",
  "version": "1.0.0",
  "description": "DH Cloud central API and database platform for the DH staff portal, client portal, and website.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "npm run prisma:deploy && node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "check": "npm run prisma:generate && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhwebservices/cloud.git"
  },
  "keywords": [],
